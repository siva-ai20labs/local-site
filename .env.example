# Prisma SQLite database (path is relative to prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# HMAC secret used to sign session cookies — set a long random string in real envs
SESSION_SECRET="change-me-to-a-long-random-string"

# Seeded admin credentials (consumed by prisma/seed.ts)
ADMIN_EMAIL="admin@localsite.ai"
ADMIN_PASSWORD="admin1234"

# Optional non-admin demo user (consumed by prisma/seed.ts)
USER_EMAIL="viewer@localsite.ai"
USER_PASSWORD="viewer1234"

# Optional: enable real Apify Google Maps scraping.
# If APIFY_TOKEN is unset/empty, the app falls back to the built-in seed/mock provider.
APIFY_TOKEN=""
APIFY_ACTOR_ID="compass~crawler-google-places"

